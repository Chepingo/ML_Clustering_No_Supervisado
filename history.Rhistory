################# SVM
# Predecir si es legendario o no
set.seed(1234)
idx <- createDataPartition(data_pokemon_5$Legendary.Status, p = 0.7, list = FALSE)
train <- data_pokemon_5[idx, ]
test <- data_pokemon_5[-idx, ]
# Asegurar que la variable objetivo es factor con niveles correctos
train$Legendary.Status <- factor(train$Legendary.Status, levels = c("False", "True"))
test$Legendary.Status <- factor(test$Legendary.Status, levels = c("False", "True"))
# Eliminar variables no numéricas (excepto la objetivo)
train <- train[, sapply(train, is.numeric) | names(train) == "Legendary.Status"]
test <- test[, sapply(test, is.numeric) | names(test) == "Legendary.Status"]
# Configuración de control con SMOTE
ctrl <- trainControl(
method = "repeatedcv",
number = 10,
repeats = 3,
classProbs = TRUE,
summaryFunction = twoClassSummary,
sampling = "smote",
savePredictions = "final",
verboseIter = TRUE
)
# Grid de parámetros para SVM
svmGrid <- expand.grid(
sigma = c(0.001, 0.005, 0.01, 0.05),
C = c(0.25, 0.5, 1, 2, 4)
)
# Preprocesamiento
preproc <- c("center", "scale")
# Entrenamiento del modelo SVM con validación cruzada
set.seed(1234)
svm_model <- train(
Legendary.Status ~ .,
data = train,
method = "svmRadial",
metric = "ROC",
preProcess = preproc,
tuneGrid = svmGrid,
trControl = ctrl
)
