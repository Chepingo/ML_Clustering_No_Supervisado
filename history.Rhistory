library(caret)
library(pROC)
set.seed(1234)
# 1. Separar en train / validation / test (60/20/20)
idx_train <- createDataPartition(data_pokemon_5$Legendary.Status, p = 0.6, list = FALSE)
train <- data_pokemon_5[idx_train, ]
remaining <- data_pokemon_5[-idx_train, ]
idx_val <- createDataPartition(remaining$Legendary.Status, p = 0.5, list = FALSE)
validation <- remaining[idx_val, ]
test <- remaining[-idx_val, ]
# 2. Convertir clase a factor con niveles
for (df in list(train, validation, test)) {
df$Legendary.Status <- factor(df$Legendary.Status, levels = c("False", "True"))
}
# 3. Control de entrenamiento
ctrl <- trainControl(method = "cv", number = 5, classProbs = TRUE, summaryFunction = twoClassSummary)
# 4. Entrenar modelos base
model_rf    <- train(Legendary.Status ~ ., data = train, method = "rf",    trControl = ctrl, metric = "ROC")
model_knn   <- train(Legendary.Status ~ ., data = train, method = "knn",   trControl = ctrl, metric = "ROC", preProcess = c("center", "scale"))
model_rpart <- train(Legendary.Status ~ ., data = train, method = "rpart", trControl = ctrl, metric = "ROC")
# 5. Obtener predicciones en validation set
pred_rf    <- predict(model_rf,    newdata = validation, type = "prob")[, "True"]
pred_knn   <- predict(model_knn,   newdata = validation, type = "prob")[, "True"]
pred_rpart <- predict(model_rpart, newdata = validation, type = "prob")[, "True"]
# 6. Construir set para modelo blending
blending_df <- data.frame(
rf    = pred_rf,
knn   = pred_knn,
rpart = pred_rpart,
target = validation$Legendary.Status
)
# 7. Meta-modelo (regresión logística)
meta_model <- train(target ~ ., data = blending_df, method = "glm", trControl = ctrl, metric = "ROC")
# 8. Evaluación en TEST
# Obtener predicciones base en test
test_rf    <- predict(model_rf,    newdata = test, type = "prob")[, "True"]
test_knn   <- predict(model_knn,   newdata = test, type = "prob")[, "True"]
test_rpart <- predict(model_rpart, newdata = test, type = "prob")[, "True"]
test_blend_input <- data.frame(rf = test_rf, knn = test_knn, rpart = test_rpart)
# Predicción final
probs <- predict(meta_model, newdata = test_blend_input, type = "prob")[, "True"]
preds <- factor(ifelse(probs > 0.5, "True", "False"), levels = c("False", "True"))
# Matriz de confusión
conf_matrix <- confusionMatrix(preds, test$Legendary.Status, positive = "True")
# Matriz de confusión
conf_matrix <- confusionMatrix(preds, test$Legendary.Status)
print(conf_matrix)
# Curva ROC
roc_obj <- roc(test$Legendary.Status, probs, levels = c("False", "True"))
plot(roc_obj, main = "Curva ROC - Blending (rf + knn + rpart)")
print(auc(roc_obj))
savehistory("~/Maquinas de aprendizaje/protocolo Felina/pokemon_analisis/history.Rhistory")
