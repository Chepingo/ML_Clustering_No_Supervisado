set.seed(123)
# 1. Separar train/test
idx   <- createDataPartition(data_pokemon_5$Legendary.Status, p = 0.7, list = FALSE)
train <- data_pokemon_5[idx, ]
test  <- data_pokemon_5[-idx, ]
# 2. Asegurar que la clase objetivo es factor con niveles correctos
train$Legendary.Status <- factor(train$Legendary.Status, levels = c("False", "True"))
test$Legendary.Status  <- factor(test$Legendary.Status,  levels = c("False", "True"))
# 3. Eliminar variables no numéricas
train <- train[, sapply(train, is.numeric) | names(train) == "Legendary.Status"]
test  <- test[,  sapply(test,  is.numeric) | names(test)  == "Legendary.Status"]
# 4. Eliminar columnas de varianza cero
nzv <- nearZeroVar(train)
if (length(nzv) > 0) {
train <- train[, -nzv]
test  <- test[,  -nzv]
}
# 5. Control de entrenamiento mínimo (5-fold CV, sin repeticiones)
ctrl <- trainControl(
method            = "cv",
number            = 5,
classProbs        = TRUE,
summaryFunction   = twoClassSummary,
savePredictions   = "final"
)
# 6. Entrenar modelos base mínimos: SVM y Random Forest
models_list <- caretList(
Legendary.Status ~ .,
data       = train,
trControl  = ctrl,
metric     = "ROC",
preProcess = c("center", "scale"),
tuneLength = 2,
methodList = c("svmRadial", "rf")
)
# 7. Stacking con regresión logística
stack_model <- caretStack(
models_list,
method    = "glm",
metric    = "ROC",
trControl = ctrl
)
# 8. Predicción y evaluación
probs <- predict(stack_model, newdata = test)
probs <- as.numeric(as.character(probs))  # asegurar que sea numérico
# Clasificación binaria
preds <- factor(ifelse(probs > 0.5, "True", "False"), levels = c("False", "True"))
confusionMatrix(preds, test$Legendary.Status, positive = "True")
# Curva ROC
roc_obj <- roc(test$Legendary.Status, probs)
print(auc(roc_obj))
# Predicción
probs <- predict(stack_model, newdata = test)
# Asegurar numérico válido
if (is.factor(probs)) {
probs <- as.numeric(levels(probs))[probs]
}
# Evaluar solo si son del mismo largo
if (length(probs) == length(test$Legendary.Status) && !any(is.na(probs))) {
preds <- factor(ifelse(probs > 0.5, "True", "False"), levels = c("False", "True"))
print(confusionMatrix(preds, test$Legendary.Status))
roc_obj <- roc(test$Legendary.Status, probs)
print(auc(roc_obj))
plot(roc_obj)
} else {
cat("Error: probs contiene NA o longitudes no coinciden.\n")
}
