idx   <- createDataPartition(data_pokemon_5$Legendary.Status, p = 0.7, list = FALSE)
train <- data_pokemon_5[idx, ]
test  <- data_pokemon_5[-idx, ]
# Eliminar variables de varianza cero
nzv <- nearZeroVar(train)
if (length(nzv) > 0) {
train <- train[, -nzv]
test  <- test[, -nzv]
}
# Control mínimo
ctrl <- trainControl(
method          = "repeatedcv",
number          = 5,
repeats         = 1,
classProbs      = TRUE,
summaryFunction = twoClassSummary,
savePredictions = "final"
)
# Modelos base más rápidos posibles
models_fast <- caretList(
Legendary.Status ~ .,
data       = train,
trControl  = ctrl,
metric     = "ROC",
preProcess = c("center", "scale"),
tuneLength = 2,
methodList = c("svmRadial", "rf", "knn")
)
# Meta-modelo (stacking)
stack_ctrl <- ctrl
stack_model <- caretStack(
models_fast,
method    = "glm",
metric    = "ROC",
trControl = stack_ctrl
)
# Evaluación rápida
probs <- predict(stack_model, test, type = "prob")
preds <- factor(ifelse(probs > 0.5, "True", "False"), levels = c("False", "True"))
library(caret)
confusionMatrix(preds, test$Legendary.Status, positive = "True")
