library(dplyr)
# 1. Matriz de correlación
num_idx   <- sapply(data_pok_3, is.numeric)
datos_num <- data_pok_3[, num_idx]
corr_mat  <- cor(datos_num, use = "pairwise.complete.obs")
# 2. Convertir a data.frame “long”
corr_long <- as.data.frame(as.table(corr_mat))
# as.table() crea columnas Var1, Var2 y Freq
# 3. Renombrar Freq a corr y filtrar duplicados/diagonal
top_corr <- corr_long %>%
rename(corr = Freq) %>%
filter(Var1 < Var2) %>%              # quita duplicados y diagonal
mutate(abs_corr = abs(corr)) %>%
arrange(desc(abs_corr))
# 4. Mostrar las n mejores
n <- 10
head(top_corr, n)
library(dplyr)
library(tidyr)
library(tibble)   # contiene rownames_to_column
# 1. Matriz de correlación
num_idx   <- sapply(data_pok_3, is.numeric)
datos_num <- data_pok_3[, num_idx]
corr_mat  <- cor(datos_num, use = "pairwise.complete.obs")
# 2. Convertir con rownames_to_column
corr_long <- as.data.frame(corr_mat) %>%
rownames_to_column("Var1") %>%
pivot_longer(-Var1, names_to = "Var2", values_to = "corr") %>%
filter(Var1 < Var2) %>%
mutate(abs_corr = abs(corr)) %>%
arrange(desc(abs_corr))
# 3. Mostrar las n mejores
n <- 10
head(corr_long, n)
